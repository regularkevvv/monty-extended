{
  "name": "@pydantic/monty",
  "version": "0.0.19-beta.4",
  "type": "module",
  "description": "Sandboxed Python interpreter running in crash-isolated subprocess workers",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "browser": "./dist/worker/index.browser.js",
      "node": "./dist/node.js",
      "default": "./dist/node.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "default": "./dist/node.js"
    },
    "./wasm": {
      "types": "./dist/worker/index.d.ts",
      "node": "./dist/worker/index.node.js",
      "browser": "./dist/worker/index.browser.js",
      "default": "./dist/worker/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/pydantic/monty"
  },
  "license": "MIT",
  "files": [
    "dist",
    "native-addon.js",
    "native-addon.d.ts"
  ],
  "napi": {
    "binaryName": "monty",
    "packageName": "@pydantic/monty",
    "targets": [
      "x86_64-pc-windows-msvc",
      "x86_64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-apple-darwin",
      "aarch64-unknown-linux-gnu"
    ],
    "dtsHeaderFile": "./index-header.d.ts"
  },
  "engines": {
    "node": ">= 20"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "scripts": {
    "build": "run-s build:napi build:ts",
    "build:debug": "run-s build:napi:debug build:ts",
    "build:napi": "napi build --platform --release --esm --js native-addon.js --dts native-addon.generated.d.ts",
    "build:napi:debug": "napi build --platform --esm --js native-addon.js --dts native-addon.generated.d.ts",
    "build:wasm": "cargo build -p monty-wasm-runtime --target wasm32-wasip1 --release && node scripts/copy-wasm.mjs",
    "build:ts": "tsc",
    "format": "prettier . -w",
    "lint": "oxlint .",
    "test": "vitest run",
    "test:browser": "vitest --config vitest.browser.config.ts run",
    "assemble-packages": "node scripts/assemble-packages.mjs",
    "create-platform-packages": "node scripts/create-platform-packages.mjs"
  },
  "devDependencies": {
    "@bjorn3/browser_wasi_shim": "^0.4.1",
    "@emnapi/core": "^1.5.0",
    "@emnapi/runtime": "^1.5.0",
    "@napi-rs/cli": "^3.2.0",
    "@napi-rs/wasm-runtime": "^1.1.5",
    "@playwright/test": "^1.49.1",
    "@tybys/wasm-util": "^0.10.0",
    "@types/node": "^25.0.9",
    "@vitest/browser": "^3.2.4",
    "npm-run-all2": "^8.0.4",
    "oxlint": "^1.14.0",
    "prettier": "^3.6.2",
    "typescript": "^5.9.2",
    "vite": "^6.3.5",
    "vitest": "^3.2.4"
  },
  "prettier": {
    "printWidth": 120,
    "semi": false,
    "trailingComma": "all",
    "singleQuote": true,
    "arrowParens": "always"
  },
  "optionalDependencies": {
    "@pydantic/monty-darwin-x64": "0.0.19-beta.4",
    "@pydantic/monty-darwin-arm64": "0.0.19-beta.4",
    "@pydantic/monty-linux-x64-gnu": "0.0.19-beta.4",
    "@pydantic/monty-linux-arm64-gnu": "0.0.19-beta.4",
    "@pydantic/monty-win32-x64-msvc": "0.0.19-beta.4"
  }
}
